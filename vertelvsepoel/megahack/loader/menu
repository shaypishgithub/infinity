        TeleportService:Teleport(game.PlaceId, player)
    end)

    createButton("Server Hop", contentScroll, function()
        local s, data = pcall(function()
            return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?limit=100"))
        end)
        if s and data.data and #data.data > 0 then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, data.data[math.random(#data.data)].id, player)
        end
    end)

    createButton("Anti-Kick / Anti-Ban", contentScroll, function()
        local mt = getrawmetatable(game)
        if mt then
            local old = mt.__namecall
            setreadonly(mt, false)
            mt.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                if method == "Kick" or method == "kick" or method == "Ban" then
                    createNotification("PROTECTED", "Blocked server punishment", 3)
                    return
                end
                return old(self, ...)
            end)
            setreadonly(mt, true)
        end
    end)

    createButton("Save Config", contentScroll, function()
        saveConfig()
        createNotification("CONFIG", "Theme settings saved successfully", 3)
    end)
end

