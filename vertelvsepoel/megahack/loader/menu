local function loadHacksFromCategory(categoryName)
    clearContent()
    local data = HubData[categoryName]
    createSectionHeader(categoryName, contentScroll)
    if not data or #data == 0 then
        local lbl = Instance.new("TextLabel")
        lbl.Text = "No scripts loaded for this category."
        lbl.Font = Enum.Font.Gotham
        lbl.TextColor3 = Config.TextSecondary
        lbl.TextSize = 14
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, -40, 0, 60)
        lbl.Parent = contentScroll
        return
    end
    for _, hack in ipairs(data) do
        if type(hack) == "table" and hack[1] and hack[2] then
            createButton(hack[1], contentScroll, function()
                local s, err = pcall(hack[2])
                if not s then
                    createNotification("EXECUTION ERROR", tostring(err), 5, 7733968497)
                end
            end)
        end
    end
end

local function showAllScripts()
    clearContent()
    createSectionHeader("UNIVERSAL SEARCH", contentScroll)

    local searchBox = Instance.new("TextBox")
    searchBox.PlaceholderText = "Search scripts or categories..."
    searchBox.PlaceholderColor3 = Config.TextSecondary
    searchBox.Text = ""
    searchBox.TextColor3 = Config.TextPrimary
    searchBox.BackgroundColor3 = Config.BackgroundPanel
    searchBox.BackgroundTransparency = 0.3
    searchBox.Size = UDim2.new(1, -30, 0, 42)
    searchBox.Font = Enum.Font.Gotham
    searchBox.TextSize = 14
    searchBox.Parent = contentScroll
    mkCorner(searchBox, 10)

    local resultsContainer = Instance.new("Frame")
    resultsContainer.BackgroundTransparency = 1
    resultsContainer.Size = UDim2.new(1, -20, 0, 300)
    resultsContainer.Parent = contentScroll

    local function performSearch(query)
        for _, c in ipairs(resultsContainer:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        if query == "" then return end
        local found = 0
        for catName, hacks in pairs(HubData) do
            if type(hacks) == "table" then
                for _, hack in ipairs(hacks) do
                    if type(hack) == "table" and hack[1] and string.find(string.lower(hack[1]), string.lower(query)) then
                        createButton(hack[1] .. "  ["..catName.."]", resultsContainer, function()
                            pcall(hack[2])
                        end)
                        found = found + 1
                    end
                end
            end
        end
        if found == 0 then
            local nores = Instance.new("TextLabel")
            nores.Text = "No results found."
            nores.Font = Enum.Font.Gotham
            nores.TextColor3 = Config.TextSecondary
            nores.Parent = resultsContainer
        end
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        task.wait(0.2)
        performSearch(searchBox.Text)
    end)
end

