local function createButton(text, parent, callback, isSidebar)
    local btn = Instance.new("TextButton")
    if isSidebar then
        btn.Size = UDim2.new(1, -12, 0, 38)
        btn.BackgroundColor3 = Config.BackgroundPanel
        btn.BackgroundTransparency = 0.6
        btn.Text = "  " .. text
        btn.TextColor3 = Config.TextSecondary
        btn.TextSize = 13.5
        btn.Font = Enum.Font.Gotham
        btn.TextXAlignment = Enum.TextXAlignment.Left
    else
        btn.Size = UDim2.new(1, -20, 0, 42)
        btn.BackgroundColor3 = Config.BackgroundPanel
        btn.BackgroundTransparency = 0.4
        btn.Text = text
        btn.TextColor3 = Config.TextPrimary
        btn.TextSize = 14
        btn.Font = Enum.Font.GothamSemibold
    end
    btn.BorderSizePixel = 0
    btn.ZIndex = 5
    btn.Parent = parent
    mkCorner(btn, 10)

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1
    btnStroke.Color = Config.AccentColor
    btnStroke.Transparency = 0.8
    btnStroke.Parent = btn

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
            BackgroundTransparency = 0.2,
            TextColor3 = Config.TextPrimary
        }):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.2), {Transparency = 0.3}):Play()
    end)

    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
            BackgroundTransparency = isSidebar and 0.6 or 0.4,
            TextColor3 = isSidebar and Config.TextSecondary or Config.TextPrimary
        }):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.2), {Transparency = 0.8}):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        if isSidebar then
            for _, b in ipairs(catScroll:GetChildren()) do
                if b:IsA("TextButton") then
                    TweenService:Create(b, TweenInfo.new(0.15), {BackgroundTransparency = 0.6, TextColor3 = Config.TextSecondary}):Play()
                end
            end
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.1, TextColor3 = Config.AccentColor}):Play()
        end
        trackTab(text)
        callback()
    end)
    return btn
end

